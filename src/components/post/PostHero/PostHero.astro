---
import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import FormattedDate from "@/components/ui/FormattedDate/FormattedDate.astro";
import Tag from "@/components/ui/Tag/Tag.astro";

interface Props {
  title: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: ImageMetadata;
  tags?: string[];
}

const { title, pubDate, updatedDate, heroImage, tags } = Astro.props;
const optimizedHero = heroImage
  ? await getImage({ src: heroImage, width: 1120 })
  : null;
---

{
  heroImage && optimizedHero ? (
    <div
      class="mb-8 -mt-12 -mx-6 sm:-mx-6 xl:-mt-12 xl:-mx-25.5 min-h-[75vh] sm:min-h-[50vh] bg-cover bg-center relative"
      style={`background-image: url(${optimizedHero.src});`}
      data-hero-parallax
      role="img"
      aria-label={title}
    >
      <header class="absolute right-0 lg:right-auto bottom-0 lg:bottom-4 left-0 lg:left-4 backdrop-blur-[6px] bg-black/25 p-4 lg:max-w-xl rounded-lg">
        <h1 class="md:!text-3xl m-0 !text-white [text-shadow:_0_2px_8px_rgba(0,0,0,0.8)] block">
          {title}
        </h1>
        <div class="items-center gap-3 text-sm text-gray-300 mt-2">
          <div class="self-start py-2">
            <div class="md:min-w-[90px]">
              <FormattedDate date={pubDate} class="bg-[#000000]/50 px-1" />
              {updatedDate && (
                <span class="text-nowrap bg-[#000000]/50 px-1">
                  Updated: <FormattedDate date={updatedDate} class="italic" />
                </span>
              )}
            </div>
          </div>
          {tags && tags.length > 0 && (
            <div class="flex gap-2 flex-wrap w-full">
              {tags.map((t) => (
                <Tag tag={t} variant="dark" />
              ))}
            </div>
          )}
        </div>
      </header>
    </div>
  ) : (
    <header class="mb-8 pb-8 border-b border-gray-light">
      <h1 class="text-md md:text-5xl m-0 mb-4">{title}</h1>
      <div class="flex items-center gap-4 text-sm text-gray mb-4">
        <FormattedDate date={pubDate} />
        {updatedDate && (
          <span class="italic">
            Updated <FormattedDate date={updatedDate} />
          </span>
        )}
      </div>
      {tags && tags.length > 0 && (
        <div class="flex gap-2 flex-wrap">
          {tags.map((t) => (
            <Tag tag={t} />
          ))}
        </div>
      )}
    </header>
  )
}

<script>
  function setupHeroParallax() {
    const hero = document.querySelector<HTMLElement>("[data-hero-parallax]");
    if (!hero) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    const SPEED = 0.35;
    let ticking = false;

    function update() {
      const offset = window.scrollY * SPEED;
      hero!.style.backgroundPositionY = `calc(50% + ${offset}px)`;
      ticking = false;
    }

    function onScroll() {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    }

    update();
    window.addEventListener("scroll", onScroll, { passive: true });
  }
  setupHeroParallax();
  document.addEventListener("astro:page-load", setupHeroParallax);
</script>
