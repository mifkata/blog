{
  "name": "blog",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "nx dev",
    "dev:astro": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "vitest",
    "test:run": "vitest run",
    "storybook": "storybook dev -p 9009 --no-open",
    "storybook:build": "storybook build -o dist/storybook",
    "prepare": "husky",
    "dc:compose": "docker compose -f .devcontainer/docker-compose.yml",
    "dc:notify": "pgrep -f 'socat TCP-LISTEN:4545' >/dev/null || (nohup socat TCP-LISTEN:4545,reuseaddr,fork EXEC:.devcontainer/notifier.sh >/tmp/hostcmd.log 2>&1 & echo '🔔 Notifier started.')",
    "devcontainer": "pnpm dc:compose exec -e ITERM_SESSION_ID=$ITERM_SESSION_ID dc_blog zsh",
    "devcontainer:build": "pnpm dc:compose build",
    "devcontainer:rebuild": "pnpm dc:compose build --no-cache",
    "devcontainer:start": "pnpm dc:compose up -d && pnpm dc:notify",
    "devcontainer:stop": "pnpm dc:compose down",
    "devcontainer:restart": "pnpm devcontainer:stop && pnpm devcontainer:start"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/react": "^6.0.1",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.1.17",
    "astro": "^7.0.9",
    "marked": "^17.0.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "sharp": "^0.34.3",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.17"
  },
  "devDependencies": {
    "@storybook-astro/framework": "^1.8.0",
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/html": "^10.5.0",
    "@storybook/html-vite": "^10.5.0",
    "@storybook/react": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "eslint": "^9.39.1",
    "eslint-mdx": "^3.6.2",
    "eslint-plugin-astro": "^1.5.0",
    "eslint-plugin-mdx": "^3.6.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "nx": "^22.3.3",
    "prettier": "^3.7.3",
    "prettier-plugin-astro": "^0.14.1",
    "storybook": "^10.5.0",
    "vitest": "^4.0.16"
  },
  "lint-staged": {
    "*.{js,ts,astro}": "eslint --fix",
    "*.{js,ts,astro,css,md,mdx,json}": "prettier --write"
  }
}
